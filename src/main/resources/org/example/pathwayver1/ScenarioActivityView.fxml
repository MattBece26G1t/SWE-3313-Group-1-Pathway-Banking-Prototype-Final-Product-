<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="600.0" prefWidth="900.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.pathwayver1.ScenarioActivityController">
   <children>
      <ImageView fitHeight="600.0" fitWidth="900.0" pickOnBounds="true">
         <image>
            <Image url="@images/scenarioactivity.drawio.png" />
         </image>
      </ImageView>
      <Button fx:id="helpButton" layoutX="803.0" layoutY="12.0" mnemonicParsing="false" onAction="#handleHelp" prefHeight="48.0" prefWidth="56.0" style="-fx-background-color: transparent;;" />
      <Button fx:id="backButton" layoutX="5.0" layoutY="94.0" mnemonicParsing="false" onAction="#handleBack" prefHeight="58.0" prefWidth="146.0" style="-fx-background-color: transparent;;" />
      <Button fx:id="ideaButton" layoutX="686.0" layoutY="12.0" mnemonicParsing="false" onAction="#handleIdea" prefHeight="48.0" prefWidth="56.0" style="-fx-background-color: transparent;;" />
      <Label fx:id="scenarioTitleLabel" layoutX="199.0" layoutY="111.0" prefHeight="48.0" prefWidth="478.0" text="Label" textFill="#c49063">
         <font>
            <Font name="Myanmar Text Bold" size="20.0" />
         </font>
      </Label>
      <ImageView fx:id="beginnerBadge" fitHeight="82.0" fitWidth="98.0" layoutX="692.0" layoutY="87.0" pickOnBounds="true" preserveRatio="true" visible="false">
         <image>
            <Image url="@images/beg.drawio.png" />
         </image>
      </ImageView>
      <Label fx:id="chatBubbleLabel" alignment="TOP_LEFT" layoutX="97.0" layoutY="213.0" prefHeight="133.0" prefWidth="696.0" text="Label" wrapText="true">
         <font>
            <Font name="Myanmar Text Bold" size="12.5" />
         </font>
      </Label>
      <Label fx:id="response1Label" alignment="TOP_LEFT" layoutX="107.0" layoutY="416.0" prefHeight="65.0" prefWidth="263.0" text="Label" wrapText="true">
         <font>
            <Font name="Myanmar Text Bold" size="11.0" />
         </font>
      </Label>
      <Label fx:id="response2Label" alignment="TOP_LEFT" layoutX="438.0" layoutY="418.0" prefHeight="65.0" prefWidth="263.0" text="Label" wrapText="true">
         <font>
            <Font name="Myanmar Text Bold" size="11.0" />
         </font>
      </Label>
      <Label fx:id="response3Label" alignment="TOP_LEFT" layoutX="107.0" layoutY="500.0" prefHeight="65.0" prefWidth="263.0" text="Label" visible="false" wrapText="true">
         <font>
            <Font name="Myanmar Text Bold" size="11.0" />
         </font>
      </Label>
      <Label fx:id="response4Label" alignment="TOP_LEFT" layoutX="438.0" layoutY="502.0" prefHeight="65.0" prefWidth="263.0" text="Label" visible="false" wrapText="true">
         <font>
            <Font name="Myanmar Text Bold" size="11.0" />
         </font>
      </Label>
      <Button fx:id="response1Button" layoutX="107.0" layoutY="416.0" mnemonicParsing="false" onAction="#handleResponse1" prefHeight="65.0" prefWidth="263.0" style="-fx-background-color: transparent;;" />
      <Button fx:id="response3Button" layoutX="107.0" layoutY="500.0" mnemonicParsing="false" onAction="#handleResponse3" prefHeight="65.0" prefWidth="263.0" style="-fx-background-color: transparent;;" visible="false" />
      <Button fx:id="response2Button" layoutX="438.0" layoutY="418.0" mnemonicParsing="false" onAction="#handleResponse2" prefHeight="65.0" prefWidth="263.0" style="-fx-background-color: transparent;;" />
      <Button fx:id="response4Button" layoutX="438.0" layoutY="502.0" mnemonicParsing="false" onAction="#handleResponse4" prefHeight="65.0" prefWidth="263.0" style="-fx-background-color: transparent;;" visible="false" />
      <ImageView fx:id="advancedBadge" fitHeight="82.0" fitWidth="98.0" layoutX="693.0" layoutY="87.0" pickOnBounds="true" preserveRatio="true" visible="false">
         <image>
            <Image url="@images/adv.drawio.png" />
         </image>
      </ImageView>
   </children>
</AnchorPane>
