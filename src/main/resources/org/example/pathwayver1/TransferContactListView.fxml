<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="500.0" prefWidth="750.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.pathwayver1.TransferContactListController">
   <children>
      <ImageView fitHeight="500.0" fitWidth="750.0" pickOnBounds="true">
         <image>
            <Image url="@images/transfercontactsec.drawio.png" />
         </image>
      </ImageView>
      <Button fx:id="helpButton" layoutX="661.0" layoutY="23.0" mnemonicParsing="false" onAction="#handleHelp" prefHeight="35.0" prefWidth="45.0" style="-fx-background-color: transparent;;" />
      <Button fx:id="backButton" layoutX="14.0" layoutY="82.0" mnemonicParsing="false" onAction="#handleBack" prefHeight="47.0" prefWidth="116.0" style="-fx-background-color: transparent;;" />
      <ScrollPane fx:id="contactScrollPane" hbarPolicy="NEVER" layoutX="137.0" layoutY="174.0" prefHeight="284.0" prefWidth="479.0" style="-fx-background-color: transparent;; -fx-background: transparent;;">
         <content>
            <VBox fx:id="contactList" prefHeight="286.0" prefWidth="477.0" style="-fx-background-color: transparent;;" />
         </content>
      </ScrollPane>
   </children>
</AnchorPane>
